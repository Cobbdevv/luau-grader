{
  "productName": "Luau Grader",
  "version": "0.1.0",
  "identifier": "com.devforge.luau-grader",
  "build": {
    "frontendDist": "../src/"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Luau Auto-Grader",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; script-src 'self'"
    }
  }
}